{
  "name": "powerful-weapon",
  "productName": "Powerful Weapon",
  "version": "0.1.1",
  "description": "Tamil Bible verse study, daily WhatsApp posting and Sunday voice-note grading.",
  "main": "dist-electron/main.js",
  "author": "Andrew Johnson",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm:dev:electron\"",
    "dev:electron": "tsc -p electron/tsconfig.json -w & wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "package": "npm run build && electron-builder --publish never",
    "package:win": "npm run build && electron-builder --win --publish never",
    "package:mac": "npm run build && electron-builder --mac --publish never",
    "fix-dev": "rm -rf node_modules/electron && npm install electron --no-save && cd node_modules/electron && node install.js || true",
    "import:bible": "tsx scripts/build-bible-db.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.5.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.1.0",
    "electron-builder": "^25.0.5",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.5",
    "wait-on": "^8.0.0"
  },
  "allowScripts": {
    "electron@32.3.3": true
  }
}
